<!-- Osano + Gorgias + Accessibe Start -->
<style>
    @media (min-width: 768px) {
        .osano-cm-widget {
            width: 45px;
            height: 45px;
            bottom: 60px;
            right: 18px;

            svg {
                width: 45px;
                height: 45px;
            }
        }
        .accessibe-widget {
            width: 48px !important;
            bottom: 0px !important;
            right: 16px !important;

            img {
                height: 48px !important;
                width: 48px !important;
            }
        }
        #gorgias-chat-container iframe {
            margin-bottom: 35px !important
        }
    }
    @media (max-width: 768px) {
        .osano-cm-widget {
            width: 35px;
            height: 35px;
            bottom: 40px;
            right: 18px;

            svg {
                width: 35px;
                height: 35px;
            }
        }
        .accessibe-widget {
            width: 35px !important;
            right: 18px !important;
            bottom: -2px !important;
        
            img {
                height: 35px !important;
                width: 35px!important;
            }
        }
    }
    .osano-cm-widget {
        &:hover,
        &:focus,
        &:active {
            background: none;
            outline: none;

            &::after {
                transform: none;
                -webkit-transform: none;
                transition: none;
                -webkit-transition: none;
                content: none;
            }
        }
    }
</style>
<!-- Osano + Gorgias + Accessibe End -->

