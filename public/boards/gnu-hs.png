<div data-block="minicart" class="minicart-wrapper">
    <a id="minicart-show" class="action showcart" href="https://www.gnu.com/checkout/cart/"
       data-bind="scope: 'minicart_content'"
       onclick="dataLayer.push({'event': 'minicart_show'}); ">
        <span class="text">My Bag</span>
        <span class="counter qty empty"
              data-bind="css: { empty: !!getCartParam('summary_count') == false && !isLoading() }, blockLoader: isLoading">
            <span class="counter-number"><!-- ko text: getCartParam('summary_count') --><!-- /ko --></span>
            <span class="counter-label">
            <!-- ko if: getCartParam('summary_count') -->
                <!-- ko text: getCartParam('summary_count') --><!-- /ko -->
                <!-- ko i18n: 'items' --><!-- /ko -->
            <!-- /ko -->
            </span>
        </span>
    </a>
            <div class="block block-minicart empty">
            <div id="minicart-content-wrapper" class="minicart-content-wrapper" data-bind="scope: 'minicart_content'">
                <!-- ko template: getTemplate() --><!-- /ko -->
            </div>
                    </div>
        <script>
            /**
             * Checks if a variable is an HTML Element
             *
             * @param element
             * @returns {boolean}
             */
            function isElement(element) {
                return element instanceof Element || element instanceof HTMLDocument;
            }

            require(
                [
                    'jquery',
                    'jquery-ui-modules/widget',
                    'Magento_Ui/js/modal/modal'
                ],
                function($) {
                    var options = {
                        type: 'slide',
                        responsive: true,
                        innerScroll: false,
                        title: '',
                        buttons: [],
                        modalClass: 'minicart-modal',
                        trigger: '.minicart-wrapper .showcart',
                    };
                    $('#minicart-content-wrapper').modal(options);
                    $('.minicart-wrapper .showcart').on('click', function(e) {
                        e.preventDefault(); // prevent default behavior from redirecting customer
                    });
                    try {
                        $(document).on('ajax:addToCart', function (event, data) {
                            var displayOnAddToCart = ("" === '1');
                            if (displayOnAddToCart === false) {
                                return;
                            }
                            var secondsToDisplay = parseInt(0, 10);
                            var showCartElements = document.getElementsByClassName('showcart');

                            if (typeof showCartElements !== 'object' && showCartElements.length === 0) {
                                return;
                            }

                            var firstShowCartElement = showCartElements[0];
                            var minicartModalElements = document.getElementsByClassName('minicart-modal');

                            if (typeof minicartModalElements !== 'object' && minicartModalElements.length === 0) {
                                return;
                            }

                            var minicart = minicartModalElements[0];

                            // Checking to see if the cart is already open.
                            if ($.inArray('_show', minicart.classList) >= 0) {
                                return;
                            }

                            if (isElement(firstShowCartElement)) {
                                firstShowCartElement.click();
                                setTimeout(function() {
                                    document.body.querySelector('.minicart-modal button[data-role="closeBtn"]').click();
                                }, (secondsToDisplay * 1000));
                            }
                        });
                    } catch (e) {
                        //
                        console.log('error', e);
                    }

                }
            );
        </script>
        <script>
        window.checkout = {"shoppingCartUrl":"https:\/\/www.gnu.com\/checkout\/cart\/","checkoutUrl":"https:\/\/www.gnu.com\/checkout\/","updateItemQtyUrl":"https:\/\/www.gnu.com\/checkout\/sidebar\/updateItemQty\/","removeItemUrl":"https:\/\/www.gnu.com\/checkout\/sidebar\/removeItem\/","imageTemplate":"Magento_Catalog\/product\/image_with_borders","baseUrl":"https:\/\/www.gnu.com\/","minicartMaxItemsVisible":5,"websiteId":"14","maxItemsToDisplay":10,"storeId":"26","storeGroupId":"14","customerLoginUrl":"https:\/\/www.gnu.com\/customer\/account\/login\/","isRedirectRequired":false,"autocomplete":"off","captcha":{"user_login":{"isCaseSensitive":false,"imageHeight":50,"imageSrc":"","refreshUrl":"https:\/\/www.gnu.com\/captcha\/refresh\/","isRequired":false,"timestamp":1774301801}}};
    </script>
